# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real keys.

# ── OpenCode upstream ──────────────────────────────────────────────────────
# Your OpenCode API key (required)
OPENCODE_API_KEY=sk-...

# OpenCode go-tier endpoint (required)
UPSTREAM_URL=https://opencode.ai/zen/go/v1

# OpenCode free-tier endpoint (required if using free-tier models)
OPENCODE_FREE_URL=https://opencode.ai/zen/v1

# ── Proxy server ───────────────────────────────────────────────────────────
PORT=8080

# ── Ingress auth (optional) ────────────────────────────────────────────────
# If set, every inbound request must carry "Authorization: Bearer <value>"
# PROXY_API_KEY=change-me-to-any-secret

# ── Direct provider bypass (direct:<model> mode) ──────────────────────────
# Set these to use  model="direct:claude-opus-4-5"  in Claude Code.
# DIRECT_URL=https://api.anthropic.com
# DIRECT_KEY=sk-ant-...

# ── Model routing ──────────────────────────────────────────────────────────
# Model routing is configured in models.json — no changes needed here.
# To override a single model without editing models.json, set MODEL_MAP:
# MODEL_MAP={"my-alias":"qwen3.7-max"}
